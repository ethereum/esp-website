# mailchimp
MAILCHIMP_APIKEY=
MAILCHIMP_SERVER=
MAILCHIMP_LIST_ID=

# matomo
NEXT_PUBLIC_MATOMO_URL=
NEXT_PUBLIC_MATOMO_SITE_ID=

# salesforce (OAuth 2.0 Client Credentials flow)
# SF_PROD_LOGIN_URL must be the org's My Domain URL (e.g. https://ef-esp.my.salesforce.com),
# not login.salesforce.com — Client Credentials flow requires it.
SF_PROD_LOGIN_URL=
SF_PROD_CONSUMER_KEY=
SF_PROD_CONSUMER_SECRET=

# captcha (key/secret for testing only, check Netlify for production key if needed)
NEXT_PUBLIC_HCAPTCHA_SITEKEY=10000000-ffff-ffff-ffff-000000000001
HCAPTCHA_SECRET=0x0000000000000000000000000000000000000000

# listmonk
LISTMONK_API_USERNAME=
LISTMONK_API_ACCESS_TOKEN=

# csat survey JWT secret
CSAT_JWT_SECRET=

# glitchtip (sentry-compatible error tracking)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=